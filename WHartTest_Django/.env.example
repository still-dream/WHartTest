# 本地开发环境配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# ================================
# Redis 连接配置
# ================================
# 本地开发：连接 Docker 容器中的 Redis（端口 8911）
# Docker 部署：使用 docker-compose.yml 中的配置
CELERY_BROKER_URL=redis://127.0.0.1:8911/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:8911/0

# ================================
# Django 基础配置
# ================================
# 调试模式（生产环境请设为 False）
DJANGO_DEBUG=True

# Django 密钥（生产环境必须修改为随机字符串）
DJANGO_SECRET_KEY=dev-secret-key-change-in-production

# 允许访问的主机（生产环境请设置具体域名）
DJANGO_ALLOWED_HOSTS=*

# CORS 跨域允许的源（根据前端地址配置）
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:80

# ================================
# 数据库配置
# ================================
# 数据库类型: postgres（默认，生产推荐） 或 sqlite（本地开发）
DATABASE_TYPE=postgres
# 可选：按环境/分支切换数据库。支持：github、pro、dev
POSTGRES_DB_VARIANT=

# PostgreSQL 配置（DATABASE_TYPE=postgres 时使用）
POSTGRES_HOST=localhost
POSTGRES_PORT=8919
POSTGRES_DB=wharttest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# SQLite 数据库路径（DATABASE_TYPE=sqlite 时使用）
# DATABASE_PATH=./db.sqlite3

# 媒体文件存储路径
# 本地开发时指向项目根目录下的 data/media，与 Docker 部署保持一致
# Docker 部署时通过 docker-compose.yml 设置为 /app/data/media
MEDIA_ROOT=../data/media

# 微信官方插件宿主地址
# 本地开发默认使用 3001
WEIXIN_PLUGIN_HOST_URL=http://127.0.0.1:3001

# DOCX Editor 集成配置（主项目后端 -> docx-editor）
# `DOCX_EDITOR_BASE_URL` 填主项目后端服务端实际访问 docx-editor 的地址：
# - 主项目源码部署在宿主机：通常使用 `http://127.0.0.1:8910`
# - 主项目跑在容器里：通常使用 `http://host.docker.internal:8910`
DOCX_EDITOR_BASE_URL=http://127.0.0.1:8910
# 可选：覆盖 docx-editor 返回给浏览器的外部地址。必须填写浏览器真实可访问的地址：
# - 浏览器通过本机端口转发访问：`http://127.0.0.1:8910`
# - 浏览器可直连宿主机/域名：填实际可访问地址
DOCX_EDITOR_PUBLIC_BASE_URL=http://127.0.0.1:8910
# 必须与 docx-editor/.env 中的 DOCX_EDITOR_INTEGRATION_KEY 完全一致
DOCX_EDITOR_SERVICE_KEY=

# ================================
# Django 管理员账户（首次启动时创建）
# ================================
# DJANGO_ADMIN_USERNAME=admin
# DJANGO_ADMIN_EMAIL=admin@example.com
# DJANGO_ADMIN_PASSWORD=admin123456

# ================================
# API 基础 URL（可选）
# ================================
# 用于内部 API 调用
# DJANGO_BASE_URL=http://localhost:8000

# ================================
# Qdrant 向量数据库配置
# ================================
# 本地开发：连接 Docker 容器中的 Qdrant（端口 8918）
# Docker 部署：使用 docker-compose.yml 中的配置（http://qdrant:6333）
QDRANT_URL=http://127.0.0.1:8918
